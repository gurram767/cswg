# ===========================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored, so credentials are never committed.
# ===========================================================================

# Base URL of the application under test
BASE_URL=https://qacsconnect.cswg.com

# Test data source: json (data/users.json) or excel (data/users.xlsx)
DATA_SOURCE=json

# Run the browser headless (true for CI, false to watch locally)
HEADLESS=false

# CI flag (set to true in your pipeline)
CI=false
